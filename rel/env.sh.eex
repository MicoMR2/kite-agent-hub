#!/bin/sh

# Phoenix release env hook — runs before the BEAM starts. We use it
# to wire RELEASE_NODE to the Fly machine's private IPv6 address so
# DNSCluster (configured via DNS_CLUSTER_QUERY=kite-agent-hub.internal
# in runtime.exs:134) can resolve sibling nodes by IPv6 and form an
# actual Erlang cluster.
#
# DevOps confirmed at msg 10709 that pre-fix, nodes registered as
# kite_agent_hub@<hostname> while DNSCluster published IPv6
# addresses (fdaa:53:…) — no name match meant no connect, so PG2
# PubSub broadcasts never crossed Fly machines. Symptom: KAH chat
# was "sometimes live, sometimes refresh-only" depending on which
# machine the user happened to land on (Mico msg 10687/10690).
#
# FLY_PRIVATE_IP is injected by Fly into every machine at boot. The
# matching cookie + Erlang epmd-less long-name distribution lets two
# machines connect over the 6PN private network.

# Erlang distribution must use IPv6 (inet6_tcp) to match the
# IPv6-shaped RELEASE_NODE below. Without -proto_dist inet6_tcp the
# BEAM defaults to inet_tcp (IPv4) regardless of the node name, the
# IPv6 sibling listed by DNSCluster is unreachable, and the cluster
# silently fails to form (DevOps post-D₁ deploy flag at msg 10727).
export ERL_AFLAGS="-proto_dist inet6_tcp"

export RELEASE_DISTRIBUTION=name
export RELEASE_NODE="kite_agent_hub@${FLY_PRIVATE_IP}"

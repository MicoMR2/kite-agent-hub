<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-[#0a0a0f] text-white overflow-x-hidden relative kah-grain font-sans">
    <%!-- Nav --%>
    <header class="border-b border-white/10 bg-[#0a0a0f]/80 backdrop-blur-md sticky top-0 z-20">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <.kah_logo class="w-9 h-9 shrink-0 drop-shadow-[0_0_10px_rgba(34,197,94,0.35)]" />
          <span class="text-base font-black tracking-tight text-white">Kite Agent Hub</span>
        </div>
        <nav class="flex items-center gap-4">
          <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] shadow-[0_0_10px_rgba(255,255,255,0.02)]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
            </span>
            <span class="text-sm font-mono text-gray-300">
              Kite {KiteAgentHub.Kite.ChainId.label()}
            </span>
          </div>
          <%!-- Theme toggle — three-state (system / light / dark). The
               theme-switching JS already lives in root.html.heex; this
               just dispatches phx:set-theme via the data-phx-theme attr. --%>
          <button
            type="button"
            phx-hook="ThemeCycle"
            id="kah-theme-toggle"
            aria-label="Toggle color theme"
            class="hidden sm:inline-flex items-center justify-center h-9 w-9 rounded-full border border-white/10 bg-white/[0.04] hover:bg-white/[0.08] text-gray-300 hover:text-white transition-colors"
          >
            <span class="kah-theme-icon-light hidden">☀</span>
            <span class="kah-theme-icon-dark hidden">☾</span>
            <span class="kah-theme-icon-system">◐</span>
          </button>
          <.link
            navigate={~p"/users/log-in"}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium px-3 py-1.5"
          >
            Sign in
          </.link>
          <.link
            navigate={~p"/request-access"}
            class="rounded-xl border border-white/10 bg-white/[0.05] hover:bg-white/[0.1] px-5 py-2 text-sm font-bold transition-all shadow-[0_0_15px_rgba(255,255,255,0.05)]"
          >
            Get started →
          </.link>
        </nav>
      </div>
    </header>

    <%!-- Hero --%>
    <section class="relative z-10 mx-auto w-full px-4 sm:px-6 lg:px-8 pt-32 pb-24 text-center overflow-hidden">
      <%!-- Background glow blobs --%>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-[800px] h-[800px] rounded-full bg-white/[0.02] blur-3xl absolute -top-40 left-1/2 -translate-x-1/2">
        </div>
        <div class="w-96 h-96 rounded-full bg-[#22c55e]/[0.03] blur-3xl absolute top-40 left-1/4">
        </div>
        <div class="w-96 h-96 rounded-full bg-[#ef4444]/[0.03] blur-3xl absolute top-20 right-1/4">
        </div>
      </div>

      <div class="relative">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.02] px-4 py-1.5 text-sm font-semibold text-gray-200 mb-8 backdrop-blur-sm shadow-[0_0_15px_rgba(255,255,255,0.02)]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
          </span>
          BYO-LLM · Alpaca + Kalshi · Non-custodial · On Kite Chain
        </div>

        <h1 class="font-display text-[clamp(2.4rem,7vw,6.5rem)] font-extrabold tracking-[-0.035em] leading-[0.95] mb-10">
          <span class="text-white">Autonomous AI agents.</span>
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">
            Trade while you
          </span>
          <span
            id="hero-cycle"
            phx-hook="WordCycle"
            phx-update="ignore"
            data-words="sleep,work,cook,code,chill,live,build,swim,party,run"
            data-interval="2500"
            class="italic font-serif tracking-tight kah-glow-accent"
          >sleep.</span>
        </h1>

        <p class="text-lg sm:text-2xl text-gray-300 max-w-2xl mx-auto mb-12 leading-[1.65] font-light">
          Deploy AI trading agents that execute on Alpaca and Kalshi, scored with KCI Edge Scoring,
          and settled on Kite chain. Bring your own LLM — Claude Code, Claude Desktop, or any MCP-compatible client.
          <span class="text-white font-medium">Non-custodial by design.</span>
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <.link
            navigate={~p"/request-access"}
            phx-hook="Magnetic"
            id="hero-cta-primary"
            data-magnetic-strength="14"
            class="inline-block rounded-xl bg-[#16a34a] hover:bg-[#15803d] px-4 sm:px-10 py-3 sm:py-4 text-sm sm:text-base font-bold text-white transition-all shadow-[0_0_35px_rgba(34,197,94,0.25)] w-full sm:w-auto text-center"
          >
            Request access →
          </.link>
          <.link
            navigate={~p"/users/log-in"}
            phx-hook="Magnetic"
            id="hero-cta-secondary"
            data-magnetic-strength="10"
            class="inline-flex items-center gap-2.5 rounded-full border border-white/20 bg-gradient-to-b from-white/[0.10] to-white/[0.04] hover:from-white/[0.16] hover:to-white/[0.08] px-7 sm:px-9 py-3 sm:py-4 text-sm sm:text-base font-semibold transition-all shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_0_24px_rgba(255,255,255,0.06)] w-full sm:w-auto justify-center backdrop-blur-md"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e]"></span>
            Sign in to continue
            <span class="text-gray-400">→</span>
          </.link>
        </div>

        <p class="text-sm text-gray-400 mt-8 font-mono">
          Free on testnet · No credit card · Keys stay local
        </p>
      </div>
    </section>

    <%!-- Stats bar --%>
    <div class="border-y border-white/10 bg-white/[0.01] backdrop-blur-sm">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            BYO-LLM
          </p>
          <p class="text-[13px] text-gray-400 mt-3 font-mono uppercase tracking-widest">
            Claude Code · MCP · Any
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            BYOK
          </p>
          <p class="text-[13px] text-gray-400 mt-3 font-mono uppercase tracking-widest">
            Alpaca · Kalshi · More
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            Edge
          </p>
          <p class="text-[13px] text-gray-400 mt-3 font-mono uppercase tracking-widest">
            KCI Edge Scoring
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            Kite
          </p>
          <p class="text-[13px] text-gray-400 mt-3 font-mono uppercase tracking-widest">
            On-Chain Settlement
          </p>
        </div>
      </div>
    </div>

    <%!-- Vault transparency marker --%>
    <%= case @vault_snapshot do %>
      <% {:ok, snap} -> %>
        <div class="border-b border-white/5 bg-emerald-500/[0.025]">
          <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-[12px] font-mono">
            <div class="flex items-center gap-2 text-gray-400">
              <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e]"></span>
              <span class="uppercase tracking-widest text-[10px] font-semibold">KAH Treasury · public ledger</span>
            </div>
            <div class="flex flex-wrap items-center gap-x-6 gap-y-1 text-gray-400">
              <a
                href={"https://testnet.kitescan.ai/address/" <> snap.address}
                target="_blank"
                rel="noopener"
                class="text-gray-400 hover:text-white transition-colors underline-offset-2 hover:underline"
              >
                {String.slice(snap.address, 0, 6) <> "…" <> String.slice(snap.address, -4, 4)}
              </a>
              <span :if={snap.usdc} class="text-emerald-200">
                {Decimal.to_string(Decimal.round(snap.usdc, 2), :normal)} USDC
              </span>
              <span :if={!snap.usdc} class="text-gray-600">— USDC</span>
              <span class="text-gray-600">·</span>
              <span class="text-gray-400">
                updated {Calendar.strftime(snap.fetched_at, "%H:%M UTC")}
              </span>
            </div>
          </div>
        </div>

      <% _ -> %>
    <% end %>

    <%!-- Brand belt --%>
    <section
      id="brand-belt"
      phx-hook="RevealOnScroll"
      class="kah-revealable kah-reveal relative z-10 border-y border-white/10 bg-white/[0.015] backdrop-blur-sm"
    >
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-7 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs font-mono uppercase tracking-[0.22em] text-gray-400">
          Wired into
        </p>
        <%!-- Venue wordmarks tinted to match each platform's in-app pill color
             (see .kah-platform-* in app.css). Parity with the dashboard so users
             see the same visual language pre/post sign-in. --%>
        <div class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 text-[15px] sm:text-base font-display font-bold tracking-tight">
          <a
            href="https://alpaca.markets"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#fde047] hover:underline underline-offset-4 transition-all"
          >Alpaca</a>
          <span class="text-gray-700">·</span>
          <a
            href="https://kalshi.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#4ade80] hover:underline underline-offset-4 transition-all"
          >Kalshi</a>
          <span class="text-gray-700">·</span>
          <a
            href="https://oanda.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#fb923c] hover:underline underline-offset-4 transition-all"
          >OANDA</a>
          <span class="text-gray-700">·</span>
          <a
            href="https://polymarket.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#60a5fa] hover:underline underline-offset-4 transition-all"
          >Polymarket</a>
          <span class="text-gray-700">·</span>
          <a
            href="https://kitescan.ai"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#2dd4bf] hover:underline underline-offset-4 transition-all"
          >Kite Chain</a>
          <span class="text-gray-700">·</span>
          <a
            href="https://agentpassport.ai/quickstart/#simple-setup"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#ef4444] hover:underline underline-offset-4 transition-all"
          >Kite Passport</a>
        </div>
        <p class="text-xs font-mono uppercase tracking-[0.22em] text-gray-400">
          {KiteAgentHub.Kite.ChainId.label()}
        </p>
      </div>
    </section>

    <%!-- Features grid — scoped to dark theme so hardcoded white text
         keeps contrast against the dark gradient sections regardless
         of the visitor's chosen page-wide theme. --%>
    <section
      id="features"
      phx-hook="RevealOnScroll"
      class="kah-dark-section kah-revealable kah-reveal relative z-10 mx-auto w-full px-4 sm:px-6 lg:px-8 py-32 bg-[#0a0a0f]"
    >
      <div class="max-w-3xl mb-20">
        <p class="text-[11px] font-mono uppercase tracking-[0.22em] text-[#22c55e] mb-5">
          The platform · 01
        </p>
        <h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold text-white mb-6 tracking-[-0.03em] leading-[1.02]">
          Built for the
          <span class="italic font-serif kah-glow-accent">edge</span>.
          Engineered for the long game.
        </h2>
        <p class="text-lg text-gray-300 font-light leading-relaxed">
          Every component designed for autonomous on-chain trading — from signal to settlement. No black boxes, no custody, no surprises.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <%= for {title, desc, icon} <- [
        {"BYO-LLM via MCP", "Connect Claude Code, Claude Desktop, or any MCP-compatible LLM with a single copy-paste block. No platform API charges — you bring the intelligence.", "hero-cpu-chip"},
        {"Bring Your Own Keys", "Connect Alpaca paper trading, Kalshi demo markets — with Webull and Robinhood on the roadmap. Keys are AES-256-GCM encrypted at rest. Never logged.", "hero-arrows-right-left"},
        {"KCI Edge Scoring", "Every open position is scored 0-100 on entry quality, momentum, risk/reward, and liquidity. Exit suggestions for weak positions, hold signals for strong ones.", "hero-chart-bar-square"},
        {"Multi-Agent Teams", "Deploy trading agents that execute, research agents that signal, and conversational agents that coordinate. Build a full team — only traders need a wallet.", "hero-user-group"},
        {"Non-Custodial by Design", "Private keys never touch the server. We store only your public wallet address. Your funds, your keys — full stop.", "hero-shield-check"},
        {"Vault-Enforced Limits", "Set daily USD caps, per-trade limits, and max open positions per agent. Limits enforced server-side before any trade queues.", "hero-lock-closed"}
      ] do %>
          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-8 hover:border-white/20 hover:bg-white/[0.04] transition-all duration-300 group">
            <div class="h-12 w-12 rounded-xl border border-white/10 bg-white/[0.05] flex items-center justify-center mb-6 group-hover:shadow-[0_0_15px_rgba(255,255,255,0.1)] transition-all duration-300">
              <.icon name={icon} class="w-6 h-6 text-white" />
            </div>
            <h3 class="text-lg font-bold text-white mb-3 tracking-tight">{title}</h3>
            <p class="text-gray-300 text-base leading-relaxed font-light">
              {desc}
            </p>
          </div>
        <% end %>
      </div>
    </section>

    <%!-- How it works — scoped dark, same reason as the features
         section: hardcoded white text needs a dark canvas. --%>
    <section
      id="how"
      phx-hook="RevealOnScroll"
      class="kah-dark-section kah-revealable kah-reveal relative z-10 border-t border-white/10 bg-[#0a0a0f]"
    >
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-32">
        <div class="max-w-3xl mb-20">
          <p class="text-[11px] font-mono uppercase tracking-[0.22em] text-[#22c55e] mb-5">
            Get live · 02
          </p>
          <h2 class="font-display text-4xl sm:text-5xl md:text-6xl font-extrabold text-white tracking-[-0.03em] leading-[1.02] mb-6">
            From zero to autonomous in
            <span class="italic font-serif">under ten minutes.</span>
          </h2>
          <p class="text-lg text-gray-300 font-light max-w-2xl">
            Four moves. No setup tax. Sign in, plug your venues, point an LLM at the system prompt — your agent takes it from there.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              1
            </div>
            <h3 class="text-base font-bold text-white mb-3">Register & Add Keys</h3>
            <p class="text-gray-300 text-[15px] leading-relaxed font-light">
              Sign up in seconds. Add your Alpaca paper keys and Kalshi demo credentials. AES-256-GCM encrypted at rest — never logged.
            </p>
            <div class="mt-4 text-[11px] font-mono text-gray-400 uppercase tracking-widest">
              Alpaca · Kalshi · more coming
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              2
            </div>
            <h3 class="text-base font-bold text-white mb-3">Connect Kite Wallet</h3>
            <p class="text-gray-300 text-[15px] leading-relaxed font-light">
              Paste your Kite testnet wallet address. Deploy a TradingAgentVault to enforce on-chain spend limits. Get testnet tokens at faucet.gokite.ai.
            </p>
            <div class="mt-4 text-[11px] font-mono text-gray-400 uppercase tracking-widest">
              Required for trading agents only
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              3
            </div>
            <h3 class="text-base font-bold text-white mb-3">Create Your Agent</h3>
            <p class="text-gray-300 text-[15px] leading-relaxed font-light">
              Choose your agent type: Trading (executes live trades), Research (signals only), or Conversational (analysis & coordination). Each gets a tailored system prompt.
            </p>
            <div class="mt-4 text-[11px] font-mono text-gray-400 uppercase tracking-widest">
              Trading · Research · Conversational
            </div>
          </div>

          <div class="rounded-2xl border border-[#22c55e]/30 bg-[#22c55e]/[0.05] backdrop-blur-md p-7 text-center relative hover:border-[#22c55e]/50 hover:bg-[#22c55e]/[0.08] transition-all">
            <div class="w-12 h-12 rounded-full border border-[#22c55e]/50 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_25px_rgba(34,197,94,0.2)] text-[#22c55e]">
              4
            </div>
            <h3 class="text-base font-bold text-white mb-3">Make Your First Trade</h3>
            <p class="text-gray-300 text-[15px] leading-relaxed font-light">
              Copy your agent's system prompt and paste it into Claude Code, Claude Desktop, or any MCP-compatible LLM. Your agent scores edge, picks a market, and executes.
            </p>
            <div class="mt-4 inline-flex items-center gap-2 text-xs text-[#22c55e] font-semibold tracking-wider uppercase">
              <span class="w-2 h-2 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
              </span>
              Fully autonomous
            </div>
          </div>
        </div>
      </div>
    </section>

    <%!-- CTA — full-bleed close --%>
    <section
      id="closing"
      phx-hook="RevealOnScroll"
      class="kah-revealable kah-reveal relative z-10 border-t border-white/10 overflow-hidden"
    >
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0f] via-[#0d1c14] to-[#0a0a0f]">
        </div>
        <div class="w-[900px] h-[900px] rounded-full bg-[#22c55e]/[0.06] blur-3xl absolute -top-40 left-1/2 -translate-x-1/2">
        </div>
      </div>
      <div class="relative mx-auto max-w-5xl w-full px-4 sm:px-6 lg:px-8 py-40 text-center">
        <p class="text-[11px] font-mono uppercase tracking-[0.22em] text-[#22c55e] mb-6">
          Ready · 03
        </p>
        <h2 class="font-display text-4xl sm:text-6xl md:text-7xl font-extrabold text-white mb-10 tracking-[-0.035em] leading-[0.98]">
          Your team of agents is
          <br class="hidden sm:block" />
          <span class="italic font-serif">already trading.</span>
        </h2>
        <p class="text-gray-300 mb-14 text-lg sm:text-xl max-w-2xl mx-auto font-light leading-[1.6]">
          Free on testnet. No credit card. Keys stay on your machine — always. Request access, hop on a fifteen-minute call, get a one-time invite code.
        </p>
        <.link
          navigate={~p"/request-access"}
          phx-hook="Magnetic"
          id="closing-cta"
          data-magnetic-strength="20"
          class="inline-flex items-center gap-3 rounded-2xl bg-[#16a34a] hover:bg-[#15803d] px-14 py-6 text-base sm:text-lg font-bold text-white transition-all shadow-[0_0_60px_rgba(34,197,94,0.30)]"
        >
          Request your invite →
        </.link>
        <p class="text-[11px] text-gray-400 mt-10 font-mono uppercase tracking-[0.22em]">
          Built for the Kite AI Hackathon 2026 · Chain {KiteAgentHub.Kite.ChainId.default()}
        </p>
      </div>
    </section>

    <footer class="border-t border-white/10 bg-black/40 relative z-10 backdrop-blur-md">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-400 font-mono">
        <div class="flex items-center gap-3">
          <.kah_logo class="w-6 h-6 shrink-0" />
          <span class="font-bold text-white tracking-widest uppercase text-xs">
            Kite Agent Hub
          </span>
          <span class="text-gray-700">|</span>
          <span class="text-xs">Chain {KiteAgentHub.Kite.ChainId.default()}</span>
        </div>
        <span class="text-xs uppercase tracking-widest opacity-80">
          Non-custodial | Apache 2.0
        </span>
      </div>
    </footer>
  </div>
</Layouts.app>

<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-[#0a0a0f] text-white overflow-x-hidden relative">
    <%!-- Nav --%>
    <header class="border-b border-white/10 bg-[#0a0a0f]/80 backdrop-blur-md sticky top-0 z-20">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
        <div class="flex items-center gap-2.5">
          <div class="h-9 w-9 rounded-xl border border-white/10 bg-white/[0.03] flex items-center justify-center shadow-[0_0_15px_rgba(255,255,255,0.05)]">
            <svg
              class="h-5 w-5 text-white"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="text-base font-black tracking-tight text-white">Kite Agent Hub</span>
        </div>
        <nav class="flex items-center gap-4">
          <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/10 bg-white/[0.02] shadow-[0_0_10px_rgba(255,255,255,0.02)]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
            </span>
            <span class="text-xs font-mono text-gray-300">Kite Testnet · Chain 2368</span>
          </div>
          <.link
            navigate={~p"/users/log-in"}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium px-3 py-1.5"
          >
            Sign in
          </.link>
          <.link
            navigate={~p"/users/register"}
            class="rounded-xl border border-white/10 bg-white/[0.05] hover:bg-white/[0.1] px-5 py-2 text-sm font-bold transition-all shadow-[0_0_15px_rgba(255,255,255,0.05)]"
          >
            Get started →
          </.link>
        </nav>
      </div>
    </header>

    <%!-- Hero --%>
    <section class="relative z-10 mx-auto w-full px-4 sm:px-6 lg:px-8 pt-32 pb-24 text-center overflow-hidden">
      <%!-- Background glow blobs --%>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-[800px] h-[800px] rounded-full bg-white/[0.02] blur-3xl absolute -top-40 left-1/2 -translate-x-1/2">
        </div>
        <div class="w-96 h-96 rounded-full bg-[#22c55e]/[0.03] blur-3xl absolute top-40 left-1/4">
        </div>
        <div class="w-96 h-96 rounded-full bg-[#ef4444]/[0.03] blur-3xl absolute top-20 right-1/4">
        </div>
      </div>

      <div class="relative">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.02] px-4 py-1.5 text-xs font-semibold text-gray-300 mb-8 backdrop-blur-sm shadow-[0_0_15px_rgba(255,255,255,0.02)]">
          <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
          </span>
          BYO-LLM · Alpaca + Kalshi · Non-custodial · On Kite Chain
        </div>

        <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-black tracking-tight leading-tight mb-8">
          <span class="text-white">Autonomous AI agents.</span>
          <br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-100 to-gray-500">
            Trade while you sleep.
          </span>
        </h1>

        <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed font-light">
          Deploy AI trading agents that execute on Alpaca and Kalshi, scored with Edge Scoring,
          and settled on Kite chain. Bring your own LLM — Claude Code, Claude Desktop, or any MCP-compatible client.
          <span class="text-white font-medium">Non-custodial by design.</span>
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <.link
            navigate={~p"/users/register"}
            class="rounded-xl border border-[#22c55e]/30 bg-[#22c55e]/[0.08] hover:bg-[#22c55e]/[0.14] px-4 sm:px-10 py-3 sm:py-4 text-sm sm:text-base font-bold text-[#22c55e] transition-all shadow-[0_0_20px_rgba(34,197,94,0.08)] hover:-translate-y-0.5 transform w-full sm:w-auto text-center backdrop-blur-md"
          >
            Sign Up to Launch Your First Agent →
          </.link>
          <.link
            navigate={~p"/users/log-in"}
            class="rounded-xl border border-white/10 bg-white/[0.08] hover:bg-white/[0.12] px-4 sm:px-10 py-3 sm:py-4 text-sm sm:text-base font-bold transition-all shadow-[0_0_20px_rgba(255,255,255,0.05)] hover:-translate-y-0.5 transform w-full sm:w-auto text-center backdrop-blur-md"
          >
            Sign In to Continue Winning →
          </.link>
        </div>

        <p class="text-xs text-gray-600 mt-8 font-mono">
          Free on testnet · No credit card · Keys stay local
        </p>
      </div>
    </section>

    <%!-- Stats bar --%>
    <div class="border-y border-white/10 bg-white/[0.01] backdrop-blur-sm">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            BYO-LLM
          </p>
          <p class="text-xs text-gray-500 mt-2 font-mono uppercase tracking-widest">
            Claude Code · MCP · Any
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            BYOK
          </p>
          <p class="text-xs text-gray-500 mt-2 font-mono uppercase tracking-widest">
            Alpaca · Kalshi · More
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            Edge
          </p>
          <p class="text-xs text-gray-500 mt-2 font-mono uppercase tracking-widest">
            Edge Scoring
          </p>
        </div>
        <div class="text-center group">
          <p class="text-2xl sm:text-4xl font-black text-white tracking-tight group-hover:text-[#22c55e] transition-colors">
            Kite
          </p>
          <p class="text-xs text-gray-500 mt-2 font-mono uppercase tracking-widest">
            On-Chain Settlement
          </p>
        </div>
      </div>
    </div>

    <%!-- Features grid --%>
    <section class="relative z-10 mx-auto w-full px-4 sm:px-6 lg:px-8 py-32">
      <div class="text-center mb-20">
        <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white mb-6 tracking-tight">
          Built different. Built to win.
        </h2>
        <p class="text-lg text-gray-400 max-w-2xl mx-auto font-light">
          Every component designed for autonomous on-chain trading — from signal to settlement.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <%= for {title, desc, icon} <- [
        {"BYO-LLM via MCP", "Connect Claude Code, Claude Desktop, or any MCP-compatible LLM with a single copy-paste block. No platform API charges — you bring the intelligence.", "hero-cpu-chip"},
        {"Bring Your Own Keys", "Connect Alpaca paper trading, Kalshi demo markets — with Webull and Robinhood on the roadmap. Keys are AES-256-GCM encrypted at rest. Never logged.", "hero-arrows-right-left"},
        {"Edge Scoring", "Every open position is scored 0-100 on entry quality, momentum, risk/reward, and liquidity. Exit suggestions for weak positions, hold signals for strong ones.", "hero-chart-bar-square"},
        {"Multi-Agent Teams", "Deploy trading agents that execute, research agents that signal, and conversational agents that coordinate. Build a full team — only traders need a wallet.", "hero-user-group"},
        {"Non-Custodial by Design", "Private keys never touch the server. We store only your public wallet address. Your funds, your keys — full stop.", "hero-shield-check"},
        {"Vault-Enforced Limits", "Set daily USD caps, per-trade limits, and max open positions per agent. Limits enforced server-side before any trade queues.", "hero-lock-closed"}
      ] do %>
          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-8 hover:border-white/20 hover:bg-white/[0.04] transition-all duration-300 group">
            <div class="h-12 w-12 rounded-xl border border-white/10 bg-white/[0.05] flex items-center justify-center mb-6 group-hover:shadow-[0_0_15px_rgba(255,255,255,0.1)] transition-all duration-300">
              <.icon name={icon} class="w-6 h-6 text-white" />
            </div>
            <h3 class="text-lg font-bold text-white mb-3 tracking-tight">{title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed font-light">
              {desc}
            </p>
          </div>
        <% end %>
      </div>
    </section>

    <%!-- How it works --%>
    <section class="relative z-10 border-t border-white/10 bg-gradient-to-b from-[#0a0a0f] to-white/[0.02]">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-32">
        <div class="text-center mb-20">
          <h2 class="text-2xl sm:text-3xl md:text-5xl font-black text-white tracking-tight mb-6">
            Live in under 10 minutes
          </h2>
          <p class="text-lg text-gray-400 font-light max-w-2xl mx-auto">
            Four steps from zero to autonomous on-chain trading.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 relative">
          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              1
            </div>
            <h3 class="text-base font-bold text-white mb-3">Register & Add Keys</h3>
            <p class="text-gray-400 text-xs leading-relaxed font-light">
              Sign up in seconds. Add your Alpaca paper keys and Kalshi demo credentials. AES-256-GCM encrypted at rest — never logged.
            </p>
            <div class="mt-4 text-[10px] font-mono text-gray-600 uppercase tracking-widest">
              Alpaca · Kalshi · more coming
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              2
            </div>
            <h3 class="text-base font-bold text-white mb-3">Connect Kite Wallet</h3>
            <p class="text-gray-400 text-xs leading-relaxed font-light">
              Paste your Kite testnet wallet address. Deploy a TradingAgentVault to enforce on-chain spend limits. Get testnet tokens at faucet.gokite.ai.
            </p>
            <div class="mt-4 text-[10px] font-mono text-gray-600 uppercase tracking-widest">
              Required for trading agents only
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.02] backdrop-blur-md p-7 text-center relative hover:border-white/20 transition-all">
            <div class="w-12 h-12 rounded-full border border-white/20 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_20px_rgba(255,255,255,0.05)] text-white">
              3
            </div>
            <h3 class="text-base font-bold text-white mb-3">Create Your Agent</h3>
            <p class="text-gray-400 text-xs leading-relaxed font-light">
              Choose your agent type: Trading (executes live trades), Research (signals only), or Conversational (analysis & coordination). Each gets a tailored system prompt.
            </p>
            <div class="mt-4 text-[10px] font-mono text-gray-600 uppercase tracking-widest">
              Trading · Research · Conversational
            </div>
          </div>

          <div class="rounded-2xl border border-[#22c55e]/30 bg-[#22c55e]/[0.05] backdrop-blur-md p-7 text-center relative hover:border-[#22c55e]/50 hover:bg-[#22c55e]/[0.08] transition-all">
            <div class="w-12 h-12 rounded-full border border-[#22c55e]/50 bg-[#0a0a0f] flex items-center justify-center text-lg font-black mx-auto mb-6 shadow-[0_0_25px_rgba(34,197,94,0.2)] text-[#22c55e]">
              4
            </div>
            <h3 class="text-base font-bold text-white mb-3">Make Your First Trade</h3>
            <p class="text-gray-400 text-xs leading-relaxed font-light">
              Copy your agent's system prompt and paste it into Claude Code, Claude Desktop, or any MCP-compatible LLM. Your agent scores edge, picks a market, and executes.
            </p>
            <div class="mt-4 inline-flex items-center gap-2 text-xs text-[#22c55e] font-semibold tracking-wider uppercase">
              <span class="w-2 h-2 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
              </span>
              Fully autonomous
            </div>
          </div>
        </div>
      </div>
    </section>

    <%!-- CTA --%>
    <section class="relative z-10 border-t border-white/10 bg-[#0a0a0f]">
      <div class="mx-auto max-w-4xl w-full px-4 sm:px-6 lg:px-8 py-32 text-center relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-2xl sm:text-4xl md:text-6xl font-black text-white mb-8 tracking-tight">
            Ready to deploy your<br />
            <span class="text-gray-400">first autonomous agent?</span>
          </h2>
          <p class="text-gray-400 mb-12 text-lg max-w-xl mx-auto font-light">
            Free on testnet. No credit card. Your keys stay on your machine — always.
          </p>
          <.link
            navigate={~p"/users/register"}
            class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/[0.05] hover:bg-white/[0.1] px-12 py-5 text-lg font-bold transition-all shadow-[0_0_20px_rgba(255,255,255,0.05)] hover:-translate-y-0.5 transform backdrop-blur-md"
          >
            Create free account →
          </.link>
          <p class="text-xs text-gray-600 mt-8 font-mono">
            Built for the Kite AI Hackathon 2026 · Kite chain EVM testnet 2368
          </p>
        </div>
      </div>
    </section>

    <footer class="border-t border-white/10 bg-black/40 relative z-10 backdrop-blur-md">
      <div class="mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500 font-mono">
        <div class="flex items-center gap-3">
          <div class="h-6 w-6 rounded-lg border border-white/10 bg-white/[0.05] flex items-center justify-center">
            <svg
              class="h-3 w-3 text-white"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <span class="font-bold text-white tracking-widest uppercase text-xs">
            Kite Agent Hub
          </span>
          <span class="text-gray-700">|</span>
          <span class="text-xs">Chain 2368</span>
        </div>
        <span class="text-xs uppercase tracking-widest opacity-80">
          Non-custodial | Open source
        </span>
      </div>
    </footer>
  </div>
</Layouts.app>

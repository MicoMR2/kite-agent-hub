<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
      <.kah_logo class="w-14 h-14 mx-auto mb-5 drop-shadow-[0_0_20px_rgba(34,197,94,0.45)]" />
      <h1 class="text-2xl font-black text-white tracking-tight">Request received</h1>
      <p class="text-sm text-gray-400 mt-3">
        Thanks for your interest in Kite Agent Hub. We'll review your request and email you a one-time invite code shortly.
      </p>
      <.link
        navigate={~p"/"}
        class="inline-block mt-8 text-violet-400 hover:text-violet-300 text-sm font-semibold transition-colors"
      >
        ← Back to home
      </.link>
    </div>
  </div>
</Layouts.app>

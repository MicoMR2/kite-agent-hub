<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-[#0a0a0f] text-white overflow-x-hidden relative flex items-center justify-center px-4 py-16">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[800px] h-[800px] rounded-full bg-white/[0.02] blur-3xl absolute -top-40 left-1/2 -translate-x-1/2">
      </div>
      <div class="w-96 h-96 rounded-full bg-[#22c55e]/[0.05] blur-3xl absolute top-40 left-1/2 -translate-x-1/2">
      </div>
    </div>

    <div class="relative w-full max-w-md text-center">
      <.kah_logo class="w-14 h-14 mx-auto mb-6 drop-shadow-[0_0_24px_rgba(34,197,94,0.55)]" />
      <div class="inline-flex items-center gap-2 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/[0.08] px-3 py-1 text-[11px] font-semibold text-[#22c55e] mb-5 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
        </span>
        Request received
      </div>
      <h1 class="text-3xl font-black tracking-tight mb-4">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-300">
          Thanks for reaching out.
        </span>
      </h1>
      <p class="text-sm text-gray-300 leading-relaxed mb-8">
        We'll review your request and email you a one-time invite code shortly. The code is good for 14 days and locked to the email you submitted.
      </p>
      <.link
        navigate={~p"/"}
        class="inline-block rounded-xl border border-white/15 bg-white/[0.04] hover:bg-white/[0.08] px-6 py-3 text-sm font-semibold text-gray-200 hover:text-white transition-all shadow-[0_0_15px_rgba(255,255,255,0.04)] backdrop-blur-md"
      >
        ← Back to home
      </.link>
    </div>
  </div>
</Layouts.app>

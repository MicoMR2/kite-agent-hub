<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-[#0a0a0f] text-white overflow-x-hidden relative flex items-center justify-center px-4 py-16">
    <%!-- Background glow blobs --%>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[800px] h-[800px] rounded-full bg-white/[0.02] blur-3xl absolute -top-40 left-1/2 -translate-x-1/2">
      </div>
      <div class="w-96 h-96 rounded-full bg-violet-500/[0.05] blur-3xl absolute top-40 left-1/4">
      </div>
      <div class="w-96 h-96 rounded-full bg-[#22c55e]/[0.04] blur-3xl absolute top-20 right-1/4">
      </div>
    </div>

    <div class="relative w-full max-w-md">
      <div class="text-center mb-8">
        <.kah_logo class="w-14 h-14 mx-auto mb-6 drop-shadow-[0_0_24px_rgba(34,197,94,0.55)]" />
        <%= if @invite_only? and @invite_status.state == :valid do %>
          <div class="inline-flex items-center gap-2 rounded-full border border-[#22c55e]/30 bg-[#22c55e]/[0.08] px-3 py-1 text-[11px] font-semibold text-[#22c55e] mb-5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
            </span>
            Invite code valid
          </div>
        <% else %>
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-3 py-1 text-[11px] font-semibold text-gray-200 mb-5 backdrop-blur-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-[#22c55e] shadow-[0_0_8px_#22c55e] animate-pulse">
            </span>
            Create your account
          </div>
        <% end %>
        <h1 class="text-3xl font-black tracking-tight mb-2">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-300">
            Create your account
          </span>
        </h1>
        <p class="text-sm text-gray-300">Free on testnet. No credit card.</p>
      </div>

      <%!-- Inline-styled amber callout that reads well on both the cream
           light-mode canvas (#f5efe3) and the dark canvas (#0a0a0f).
           Tailwind's `dark:` variant fires on prefers-color-scheme, not
           the user's data-theme toggle — using dark-amber colors that
           are legible in either canvas state is the reliable path. --%>
      <%= if @invite_only? and @invite_status.state in [:invalid, :missing] do %>
        <div class="rounded-xl bg-amber-200/40 border border-amber-700/50 p-4 mb-5 text-sm text-amber-900">
          <p class="font-semibold mb-1">Invite-only signup</p>
          <p>
            You need a valid invite code to sign up.
            <.link navigate={~p"/request-access"} class="underline font-bold">
              Request access →
            </.link>
          </p>
        </div>
      <% end %>

      <div class="rounded-2xl bg-white/[0.04] border border-white/15 p-7 shadow-[0_0_30px_rgba(34,197,94,0.05)] backdrop-blur-md">
        <.form :let={f} for={@changeset} action={~p"/users/register"}>
          <div class="space-y-5">
            <%= if @invite_only? do %>
              <div>
                <label class="block text-[11px] font-bold text-gray-200 uppercase tracking-wider mb-2">
                  Invite code
                </label>
                <input
                  type="text"
                  name="invite_code"
                  value={@invite_code}
                  required
                  spellcheck="false"
                  autocomplete="off"
                  class="w-full bg-white/[0.04] border border-white/20 text-white placeholder-gray-500 rounded-xl px-4 py-3 text-sm font-mono outline-none focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/20 focus:bg-white/[0.06] transition-all"
                />
                <%= if @invite_status.state == :valid do %>
                  <p class="mt-1.5 text-xs text-[#22c55e] font-medium">✓ Valid code</p>
                <% end %>
              </div>
            <% end %>

            <div>
              <label class="block text-[11px] font-bold text-gray-200 uppercase tracking-wider mb-2">
                Email
              </label>
              <%= if @invite_only? and @invite_status.state == :valid and @invite_status[:email] do %>
                <%!-- Email-locked invite: pre-fill and freeze the field so the user
                     can't type a different address than the code was minted for.
                     Was the failure path that locked miller1997 out (msg 8819). --%>
                <.input
                  field={f[:email]}
                  type="email"
                  value={@invite_status.email}
                  readonly
                  required
                  class="w-full bg-white/[0.02] border border-white/15 text-gray-300 rounded-xl px-4 py-3 text-sm cursor-not-allowed"
                />
                <p class="mt-1.5 text-xs text-gray-400">
                  This invite is locked to <span class="text-white font-mono">{@invite_status.email}</span>.
                </p>
              <% else %>
                <.input
                  field={f[:email]}
                  type="email"
                  autocomplete="username"
                  spellcheck="false"
                  required
                  phx-mounted={JS.focus()}
                  class="w-full bg-white/[0.04] border border-white/20 text-white placeholder-gray-500 rounded-xl px-4 py-3 text-sm outline-none focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/20 focus:bg-white/[0.06] transition-all"
                />
              <% end %>
            </div>

            <div>
              <label class="block text-[11px] font-bold text-gray-200 uppercase tracking-wider mb-2">
                Password
              </label>
              <.input
                field={f[:password]}
                type="password"
                autocomplete="new-password"
                required
                class="w-full bg-white/[0.04] border border-white/20 text-white placeholder-gray-500 rounded-xl px-4 py-3 text-sm outline-none focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/20 focus:bg-white/[0.06] transition-all"
              />
            </div>

            <div>
              <label class="block text-[11px] font-bold text-gray-200 uppercase tracking-wider mb-2">
                Confirm password
              </label>
              <.input
                field={f[:password_confirmation]}
                type="password"
                autocomplete="new-password"
                required
                class="w-full bg-white/[0.04] border border-white/20 text-white placeholder-gray-500 rounded-xl px-4 py-3 text-sm outline-none focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/20 focus:bg-white/[0.06] transition-all"
              />
            </div>

            <div>
              <label class="flex items-start gap-3 text-xs text-gray-300 cursor-pointer leading-relaxed">
                <input
                  type="checkbox"
                  name="user[accept_terms]"
                  value="true"
                  required
                  class="mt-0.5 h-4 w-4 rounded border-white/30 bg-white/[0.07] text-violet-500 focus:ring-violet-500/40"
                />
                <span>
                  I agree to the
                  <a
                    href="/terms"
                    target="_blank"
                    class="text-violet-400 hover:text-violet-300 font-semibold underline"
                  >
                    Terms of Service
                  </a>
                  and <a
                    href="/privacy"
                    target="_blank"
                    class="text-violet-400 hover:text-violet-300 font-semibold underline"
                  >Privacy Policy</a>.
                </span>
              </label>
              <%= if msg = @changeset.errors[:accept_terms] do %>
                <p class="mt-1 text-xs text-red-400">{translate_error(msg)}</p>
              <% end %>
            </div>

            <button
              type="submit"
              phx-disable-with="Creating account..."
              class="w-full py-3.5 rounded-xl border border-violet-500/40 bg-gradient-to-r from-violet-600/[0.18] to-purple-600/[0.18] hover:from-violet-600/30 hover:to-purple-600/30 text-violet-200 hover:text-white font-bold text-sm transition-all shadow-[0_0_25px_rgba(139,92,246,0.18)] hover:-translate-y-0.5 transform mt-2 backdrop-blur-md"
            >
              Create account →
            </button>
          </div>
        </.form>
      </div>

      <p class="text-center text-sm text-gray-300 mt-6">
        Already have an account?
        <.link
          navigate={~p"/users/log-in"}
          class="text-violet-400 hover:text-violet-300 font-semibold transition-colors"
        >
          Sign in →
        </.link>
      </p>

      <p class="text-center text-xs text-gray-500 mt-4">
        🔒 Private keys never stored. Only your public wallet address is saved.
      </p>
    </div>
  </div>
</Layouts.app>

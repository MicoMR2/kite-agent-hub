<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <%!-- Logo --%>
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600 shadow-2xl shadow-violet-500/30 mb-5">
          <svg
            class="h-7 w-7 text-white"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h1 class="text-2xl font-black text-white tracking-tight">Create your account</h1>
        <p class="text-sm text-gray-500 mt-1">Free on testnet. No credit card.</p>
      </div>

      <%!-- Card --%>
      <div class="rounded-2xl bg-gray-900/60 border border-white/[0.12] p-8">
        <.form :let={f} for={@changeset} action={~p"/users/register"}>
          <div class="space-y-5">
            <div>
              <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                Email
              </label>
              <.input
                field={f[:email]}
                type="email"
                autocomplete="username"
                spellcheck="false"
                required
                phx-mounted={JS.focus()}
                class="w-full bg-gray-800 border border-white/[0.15] text-white placeholder-gray-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-violet-500/60 focus:ring-1 focus:ring-violet-500/30 transition-all"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                Password
              </label>
              <.input
                field={f[:password]}
                type="password"
                autocomplete="new-password"
                required
                class="w-full bg-gray-800 border border-white/[0.15] text-white placeholder-gray-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-violet-500/60 focus:ring-1 focus:ring-violet-500/30 transition-all"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                Confirm Password
              </label>
              <.input
                field={f[:password_confirmation]}
                type="password"
                autocomplete="new-password"
                required
                class="w-full bg-gray-800 border border-white/[0.15] text-white placeholder-gray-600 rounded-xl px-4 py-2.5 text-sm outline-none focus:border-violet-500/60 focus:ring-1 focus:ring-violet-500/30 transition-all"
              />
            </div>

            <button
              type="submit"
              phx-disable-with="Creating account..."
              class="w-full py-3 rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 text-white font-bold text-sm transition-all shadow-xl shadow-violet-500/20 hover:shadow-violet-500/30 mt-2"
            >
              Create account →
            </button>
          </div>
        </.form>
      </div>

      <p class="text-center text-sm text-gray-600 mt-6">
        Already have an account?
        <.link
          navigate={~p"/users/log-in"}
          class="text-violet-400 hover:text-violet-300 font-semibold transition-colors"
        >
          Sign in →
        </.link>
      </p>

      <p class="text-center text-xs text-gray-700 mt-3">
        🔒 Private keys never stored. Only your public wallet address is saved.
      </p>
    </div>
  </div>
</Layouts.app>

<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-gray-950 text-white">
  <%!-- Nav --%>
  <header class="border-b border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="h-8 w-8 rounded-lg bg-violet-600 flex items-center justify-center">
          <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="text-lg font-bold tracking-tight">Kite Agent Hub</span>
      </div>
      <nav class="flex items-center gap-4">
        <.link navigate={~p"/users/log-in"} class="text-sm text-gray-400 hover:text-white transition-colors">
          Log in
        </.link>
        <.link navigate={~p"/users/register"} class="rounded-lg bg-violet-600 hover:bg-violet-500 px-4 py-2 text-sm font-semibold transition-colors">
          Get started
        </.link>
      </nav>
    </div>
  </header>

  <%!-- Hero --%>
  <section class="mx-auto max-w-6xl px-6 py-28 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-violet-500/30 bg-violet-500/10 px-4 py-1.5 text-xs font-medium text-violet-300 mb-8">
      <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
      Live on Kite Testnet (Chain 2368)
    </div>
    <h1 class="text-5xl sm:text-6xl font-bold tracking-tight leading-tight mb-6">
      Autonomous trading agents<br />
      <span class="text-violet-400">built on Kite chain</span>
    </h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
      Deploy non-custodial vault agents with configurable spending limits. Monitor trades in real time. Your keys stay on your machine — always.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <.link navigate={~p"/users/register"} class="rounded-xl bg-violet-600 hover:bg-violet-500 px-8 py-3.5 text-base font-semibold transition-colors w-full sm:w-auto text-center">
        Create free account
      </.link>
      <.link navigate={~p"/users/log-in"} class="rounded-xl border border-gray-700 hover:border-gray-500 px-8 py-3.5 text-base font-semibold text-gray-300 hover:text-white transition-colors w-full sm:w-auto text-center">
        Sign in
      </.link>
    </div>
  </section>

  <%!-- Features --%>
  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8">
        <div class="h-10 w-10 rounded-xl bg-violet-500/15 flex items-center justify-center mb-5">
          <svg class="h-5 w-5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Non-custodial by design</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Private keys never leave your machine. The platform stores only your wallet address and vault contract — never credentials.
        </p>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8">
        <div class="h-10 w-10 rounded-xl bg-violet-500/15 flex items-center justify-center mb-5">
          <svg class="h-5 w-5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Configurable spending limits</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Set per-trade and daily USD caps per agent. Enforce max open positions. Limits are stored on-chain in the vault — the agent can't exceed them.
        </p>
      </div>

      <div class="rounded-2xl border border-gray-800 bg-gray-900 p-8">
        <div class="h-10 w-10 rounded-xl bg-violet-500/15 flex items-center justify-center mb-5">
          <svg class="h-5 w-5 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold mb-2">Real-time trade feed</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          LiveView-powered dashboard streams every trade as it settles. Track PnL, open positions, and vault balance without refreshing.
        </p>
      </div>
    </div>
  </section>

  <%!-- How it works --%>
  <section class="border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <h2 class="text-3xl font-bold text-center mb-16">Get live in three steps</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div class="text-center">
          <div class="h-12 w-12 rounded-full bg-violet-600 flex items-center justify-center text-lg font-bold mx-auto mb-4">1</div>
          <h3 class="font-semibold mb-2">Register & create org</h3>
          <p class="text-gray-400 text-sm">Sign up with email and password. An organization is created automatically — invite teammates any time.</p>
        </div>
        <div class="text-center">
          <div class="h-12 w-12 rounded-full bg-violet-600 flex items-center justify-center text-lg font-bold mx-auto mb-4">2</div>
          <h3 class="font-semibold mb-2">Onboard an agent</h3>
          <p class="text-gray-400 text-sm">Run the onboarding script to generate a wallet, deploy your TradingAgentVault, and write your .env — one command.</p>
        </div>
        <div class="text-center">
          <div class="h-12 w-12 rounded-full bg-violet-600 flex items-center justify-center text-lg font-bold mx-auto mb-4">3</div>
          <h3 class="font-semibold mb-2">Activate & monitor</h3>
          <p class="text-gray-400 text-sm">Paste your vault address to activate the agent. Watch trades stream into your dashboard in real time.</p>
        </div>
      </div>
    </div>
  </section>

  <%!-- Footer CTA --%>
  <section class="border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-20 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to deploy your first agent?</h2>
      <p class="text-gray-400 mb-8">Free on testnet. No credit card required.</p>
      <.link navigate={~p"/users/register"} class="inline-block rounded-xl bg-violet-600 hover:bg-violet-500 px-10 py-4 text-base font-semibold transition-colors">
        Create account
      </.link>
    </div>
  </section>

  <%!-- Footer --%>
  <footer class="border-t border-gray-800">
    <div class="mx-auto max-w-6xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <span>Kite Agent Hub — built on Kite chain (EVM testnet 2368)</span>
      <span>Non-custodial. Keys stay local.</span>
    </div>
  </footer>
</div>

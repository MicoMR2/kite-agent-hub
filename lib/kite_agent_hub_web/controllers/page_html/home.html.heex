<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-gray-950 text-white overflow-x-hidden">
  <%!-- Nav --%>
  <header class="border-b border-white/[0.08] bg-gray-950/80 backdrop-blur-md sticky top-0 z-20">
    <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <div class="h-9 w-9 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center shadow-lg shadow-violet-500/30">
          <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="text-base font-black tracking-tight bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">Kite Agent Hub</span>
      </div>
      <nav class="flex items-center gap-3">
        <div class="hidden sm:flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-500/10 ring-1 ring-emerald-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
          <span class="text-xs font-mono text-emerald-400">Kite Testnet · Chain 2368</span>
        </div>
        <.link
          navigate={~p"/users/log-in"}
          class="text-sm text-gray-400 hover:text-white transition-colors font-medium px-3 py-1.5"
        >
          Sign in
        </.link>
        <.link
          navigate={~p"/users/register"}
          class="rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 px-5 py-2 text-sm font-bold transition-all shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40"
        >
          Get started →
        </.link>
      </nav>
    </div>
  </header>

  <%!-- Hero --%>
  <section class="relative mx-auto max-w-7xl px-6 pt-24 pb-20 text-center overflow-hidden">
    <%!-- Background glow blobs --%>
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <div class="w-[600px] h-[600px] rounded-full bg-violet-600/15 blur-3xl absolute -top-40 left-1/2 -translate-x-1/2"></div>
      <div class="w-80 h-80 rounded-full bg-purple-500/10 blur-3xl absolute top-20 left-1/4"></div>
      <div class="w-64 h-64 rounded-full bg-indigo-500/10 blur-3xl absolute top-10 right-1/4"></div>
    </div>

    <div class="relative">
      <div class="inline-flex items-center gap-2 rounded-full border border-violet-500/30 bg-violet-500/10 px-4 py-1.5 text-xs font-semibold text-violet-300 mb-8">
        <span class="h-1.5 w-1.5 rounded-full bg-violet-400 animate-pulse"></span>
        Powered by Claude AI · Non-custodial · On Kite Chain
      </div>

      <h1 class="text-6xl sm:text-7xl font-black tracking-tight leading-[1.05] mb-8">
        <span class="text-white">Autonomous AI agents.</span><br />
        <span class="bg-gradient-to-r from-violet-400 via-purple-400 to-fuchsia-400 bg-clip-text text-transparent">
          Trade while you sleep.
        </span>
      </h1>

      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-12 leading-relaxed">
        Deploy Claude-powered trading agents on Kite chain with configurable spending limits.
        Real-time P&L tracking. Non-custodial by design. Your keys never leave your machine.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <.link
          navigate={~p"/users/register"}
          class="rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 px-10 py-4 text-base font-bold transition-all shadow-2xl shadow-violet-500/30 hover:shadow-violet-500/50 hover:-translate-y-0.5 transform w-full sm:w-auto text-center"
        >
          Launch Your First Agent →
        </.link>
        <.link
          navigate={~p"/users/log-in"}
          class="rounded-xl border border-white/[0.12] hover:border-white/25 bg-white/[0.03] hover:bg-white/[0.06] px-8 py-4 text-base font-semibold text-gray-300 hover:text-white transition-all w-full sm:w-auto text-center"
        >
          Sign in to dashboard
        </.link>
      </div>

      <p class="text-xs text-gray-600 mt-6">Free on testnet · No credit card · Keys stay local</p>
    </div>
  </section>

  <%!-- Stats bar --%>
  <div class="border-y border-white/[0.08] bg-white/[0.02]">
    <div class="mx-auto max-w-7xl px-6 py-6 grid grid-cols-2 sm:grid-cols-4 gap-6">
      <div class="text-center">
        <p class="text-3xl font-black text-white tracking-tight">Claude</p>
        <p class="text-xs text-gray-500 mt-1">AI Signal Engine</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-violet-400 tracking-tight">On-Chain</p>
        <p class="text-xs text-gray-500 mt-1">Trade Execution</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-emerald-400 tracking-tight">0</p>
        <p class="text-xs text-gray-500 mt-1">Keys Stored</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-black text-white tracking-tight">Real-time</p>
        <p class="text-xs text-gray-500 mt-1">LiveView Feed</p>
      </div>
    </div>
  </div>

  <%!-- Features grid --%>
  <section class="mx-auto max-w-7xl px-6 py-24">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-black text-white mb-4 tracking-tight">
        Built different. Built to win.
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Every component designed for autonomous on-chain trading — from signal to settlement.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-violet-500/20 to-purple-500/20 ring-1 ring-violet-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-violet-500/15 transition-all">
          <svg class="h-6 w-6 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Non-Custodial by Design</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Private keys never touch the server. We store only your wallet address and vault contract address. Your funds, your keys — full stop.
        </p>
      </div>

      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-violet-500/20 to-purple-500/20 ring-1 ring-violet-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-violet-500/15 transition-all">
          <svg class="h-6 w-6 text-violet-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Claude AI Signal Engine</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Each agent runs Claude Haiku on a configurable tick interval. It reads market data, reasons over open positions, and outputs structured trade signals.
        </p>
      </div>

      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-emerald-500/20 to-teal-500/20 ring-1 ring-emerald-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-emerald-500/15 transition-all">
          <svg class="h-6 w-6 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Live P&L Dashboard</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Phoenix LiveView streams every trade the instant it executes. Watch P&L, win rate, open positions, and wallet balance update in real time — no refreshing.
        </p>
      </div>

      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-amber-500/20 to-orange-500/20 ring-1 ring-amber-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-amber-500/15 transition-all">
          <svg class="h-6 w-6 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Vault-Enforced Spending Limits</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Set daily USD caps, per-trade limits, and max open positions per agent. Limits live in the TradingAgentVault smart contract — the agent literally cannot exceed them.
        </p>
      </div>

      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-blue-500/20 to-cyan-500/20 ring-1 ring-blue-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-blue-500/15 transition-all">
          <svg class="h-6 w-6 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Multi-Agent Workspace</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Run multiple agents in parallel — each with its own wallet, vault, and strategy. Organize your team under a shared workspace with role-based access.
        </p>
      </div>

      <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 backdrop-blur-sm p-8 hover:border-violet-500/30 hover:bg-gray-900/80 transition-all group">
        <div class="h-12 w-12 rounded-2xl bg-gradient-to-br from-fuchsia-500/20 to-pink-500/20 ring-1 ring-fuchsia-500/25 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-fuchsia-500/15 transition-all">
          <svg class="h-6 w-6 text-fuchsia-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-white mb-3">Full Trade History</h3>
        <p class="text-gray-400 text-sm leading-relaxed">
          Every trade is persisted with market, action, fill price, contracts, notional, realized P&L, and AI reasoning. Filter by status, paginate, and audit the full trail.
        </p>
      </div>
    </div>
  </section>

  <%!-- How it works --%>
  <section class="border-t border-white/[0.08] bg-gradient-to-b from-transparent to-gray-900/30">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-black text-white tracking-tight mb-4">Live in under 10 minutes</h2>
        <p class="text-gray-400">Three steps from zero to autonomous on-chain trading.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
        <%!-- Connector lines (desktop only) --%>
        <div class="hidden md:block absolute top-14 left-1/3 right-1/3 h-px bg-gradient-to-r from-violet-500/40 to-violet-500/40" style="width: calc(100% / 3 - 2rem); left: calc(100% / 3 + 1rem);"></div>

        <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 p-8 text-center relative">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-xl font-black mx-auto mb-6 shadow-xl shadow-violet-500/30">1</div>
          <h3 class="text-lg font-bold text-white mb-3">Register & Create Org</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Sign up with email and password. A workspace is automatically provisioned — invite teammates any time.
          </p>
          <div class="mt-6 inline-flex items-center gap-1.5 text-xs text-violet-400 font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-400"></span> ~30 seconds
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.12] bg-gray-900/60 p-8 text-center relative">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center text-xl font-black mx-auto mb-6 shadow-xl shadow-violet-500/30">2</div>
          <h3 class="text-lg font-bold text-white mb-3">Deploy Vault Contract</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Run the onboarding script to generate a wallet, deploy TradingAgentVault on testnet, and fund from the faucet.
          </p>
          <code class="mt-4 block text-xs font-mono text-violet-300 bg-gray-950 border border-white/[0.08] rounded-lg px-3 py-2">
            python scripts/agent_onboard.py
          </code>
        </div>

        <div class="rounded-2xl border border-emerald-500/20 bg-emerald-900/10 p-8 text-center">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-xl font-black mx-auto mb-6 shadow-xl shadow-emerald-500/30">3</div>
          <h3 class="text-lg font-bold text-white mb-3">Activate & Watch It Go</h3>
          <p class="text-gray-400 text-sm leading-relaxed">
            Paste your vault address in the dashboard. AgentRunner starts ticking. Claude generates signals. Trades settle on-chain — live.
          </p>
          <div class="mt-6 inline-flex items-center gap-1.5 text-xs text-emerald-400 font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span> Fully autonomous
          </div>
        </div>
      </div>
    </div>
  </section>

  <%!-- CTA --%>
  <section class="border-t border-white/[0.08]">
    <div class="mx-auto max-w-4xl px-6 py-28 text-center relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-20">
        <div class="w-96 h-96 rounded-full bg-violet-600 blur-3xl"></div>
      </div>
      <div class="relative">
        <h2 class="text-5xl font-black text-white mb-6 tracking-tight">
          Ready to deploy your<br />
          <span class="bg-gradient-to-r from-violet-400 to-purple-400 bg-clip-text text-transparent">
            first autonomous agent?
          </span>
        </h2>
        <p class="text-gray-400 mb-10 text-lg max-w-xl mx-auto">
          Free on testnet. No credit card. Your keys stay on your machine — always.
        </p>
        <.link
          navigate={~p"/users/register"}
          class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 px-12 py-5 text-lg font-bold transition-all shadow-2xl shadow-violet-500/40 hover:shadow-violet-500/60 hover:-translate-y-0.5 transform"
        >
          Create free account →
        </.link>
        <p class="text-xs text-gray-600 mt-5">
          Built for the Kite AI Hackathon 2026 · Kite chain EVM testnet 2368
        </p>
      </div>
    </div>
  </section>

  <%!-- Footer --%>
  <footer class="border-t border-white/[0.08] bg-gray-950">
    <div class="mx-auto max-w-7xl px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-600">
      <div class="flex items-center gap-2.5">
        <div class="h-6 w-6 rounded-lg bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center">
          <svg class="h-3.5 w-3.5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <span class="font-semibold text-gray-500">Kite Agent Hub</span>
        <span class="text-gray-700">·</span>
        <span>Kite chain EVM testnet 2368</span>
      </div>
      <span>Non-custodial · Keys stay local · Open source</span>
    </div>
  </footer>
</div>

<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-md text-center">
      <.kah_logo class="w-14 h-14 mx-auto mb-6 drop-shadow-[0_0_20px_rgba(34,197,94,0.45)]" />

      <h1 class="text-2xl font-black text-white mb-2">
        Welcome, {@user.email}
      </h1>
      <p class="text-gray-500 text-sm mb-8">Click below to continue to your dashboard.</p>

      <div class="rounded-2xl bg-gray-900/60 border border-white/[0.12] p-8">
        <.form
          for={@form}
          id="login_form"
          action={
            if @user.confirmed_at,
              do: ~p"/users/log-in",
              else: ~p"/users/log-in?_action=confirmed"
          }
          phx-mounted={JS.focus_first()}
        >
          <input type="hidden" name={@form[:token].name} value={@form[:token].value} />
          <input type="hidden" name={@form[:remember_me].name} value="true" />
          <button
            type="submit"
            phx-disable-with="Signing in..."
            class="w-full py-3 rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 text-white font-bold text-sm transition-all shadow-xl shadow-violet-500/20 hover:shadow-violet-500/30"
          >
            Go to Dashboard →
          </button>
        </.form>
      </div>
    </div>
  </div>
</Layouts.app>

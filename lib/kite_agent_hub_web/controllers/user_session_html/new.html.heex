<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-md">
      <%!-- Logo --%>
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600 shadow-2xl shadow-violet-500/30 mb-5">
          <svg
            class="h-7 w-7 text-white"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h1 class="text-2xl font-black text-white tracking-tight">Welcome back</h1>
        <p class="text-sm text-gray-500 mt-1">
          <%= if @current_scope do %>
            Reauthenticate to continue
          <% else %>
            Sign in to your Kite Agent Hub
          <% end %>
        </p>
      </div>

      <%!-- Card --%>
      <div class="rounded-2xl bg-gray-900/60 border border-white/[0.12] p-8">
        <.form :let={f} for={@form} as={:user} id="login_form_password" action={~p"/users/log-in"}>
          <div class="space-y-5">
            <div>
              <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                Email
              </label>
              <.input
                readonly={!!@current_scope}
                field={f[:email]}
                type="email"
                autocomplete="username"
                spellcheck="false"
                required
                phx-mounted={JS.focus()}
                class="w-full"
              />
            </div>

            <div>
              <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">
                Password
              </label>
              <.input
                field={f[:password]}
                type="password"
                autocomplete="current-password"
                spellcheck="false"
                class="w-full"
              />
            </div>

            <input type="hidden" name={@form[:remember_me].name} value="true" />

            <button
              type="submit"
              class="w-full py-3 rounded-xl bg-gradient-to-r from-violet-600 to-purple-600 hover:from-violet-500 hover:to-purple-500 text-white font-bold text-sm transition-all shadow-xl shadow-violet-500/20 hover:shadow-violet-500/30 mt-2"
            >
              Sign in →
            </button>
          </div>
        </.form>

        <%= if @workos_enabled do %>
          <div class="flex items-center gap-3 my-6">
            <div class="flex-1 h-px bg-white/[0.08]"></div>
            <span class="text-xs text-gray-600 font-medium">or</span>
            <div class="flex-1 h-px bg-white/[0.08]"></div>
          </div>

          <.link
            href={~p"/auth/workos"}
            id="workos-sso-btn"
            class="flex items-center justify-center gap-3 w-full rounded-xl border border-white/[0.12] bg-white/[0.03] hover:bg-white/[0.06] px-4 py-3 text-sm font-semibold text-gray-300 hover:text-white transition-all"
          >
            <svg
              class="h-4 w-4 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            Continue with SSO
          </.link>
        <% end %>
      </div>

      <p class="text-center text-sm text-gray-600 mt-6">
        No account?
        <.link
          navigate={~p"/users/register"}
          class="text-violet-400 hover:text-violet-300 font-semibold transition-colors"
        >
          Create one free →
        </.link>
      </p>
    </div>
  </div>
</Layouts.app>

<Layouts.app flash={@flash} current_scope={@current_scope}>
  <div class="relative min-h-screen bg-[#0a0a0f] flex items-center justify-center px-4 py-10 overflow-hidden">
    <KiteAgentHubWeb.Components.QuorumBackground.background />

    <div class="relative z-10 w-full max-w-[440px] kah-panel px-7 pt-7 pb-6">
      <div class="flex items-center justify-between mb-1">
        <.link
          navigate={~p"/"}
          class="text-[11px] font-semibold text-gray-400 hover:text-white transition-colors"
        >
          ← Back to home
        </.link>
        <span class="kah-eyebrow">Chain ID 2368</span>
      </div>

      <div class="flex items-center gap-[10px] mt-4">
        <.kah_logo class="h-7 w-7 drop-shadow-[0_0_16px_rgba(34,197,94,0.45)]" />
        <span class="text-[12px] font-black text-white tracking-[-0.01em]">Kite Agent Hub</span>
      </div>

      <h1 class="text-[28px] font-black text-white leading-[1.05] tracking-[-0.02em] mt-6">
        Welcome back.
      </h1>
      <p class="mt-[10px] mb-[22px] text-[13px] text-gray-400 font-light leading-[1.6]">
        <%= if @current_scope do %>
          Reauthenticate to continue.
        <% else %>
          Pick up where your agents left off.
        <% end %>
      </p>

      <.form
        :let={f}
        for={@form}
        as={:user}
        id="login_form_password"
        action={~p"/users/log-in"}
        class="flex flex-col gap-[14px]"
      >
        <div>
          <label class="kah-eyebrow block mb-[6px]" for="user_email">Email</label>
          <.input
            readonly={!!@current_scope}
            field={f[:email]}
            id="user_email"
            type="email"
            autocomplete="username"
            spellcheck="false"
            required
            phx-mounted={JS.focus()}
            class="kah-field-input"
          />
        </div>

        <div>
          <label class="kah-eyebrow block mb-[6px]" for="user_password">Password</label>
          <.input
            field={f[:password]}
            id="user_password"
            type="password"
            autocomplete="current-password"
            spellcheck="false"
            class="kah-field-input"
          />
        </div>

        <input type="hidden" name={@form[:remember_me].name} value="true" />

        <button type="submit" class="kah-btn-primary mt-[6px] w-full">
          Sign in
        </button>
      </.form>

      <%= if @workos_enabled do %>
        <div class="flex items-center gap-3 my-[18px]">
          <div class="flex-1 h-px bg-white/[0.06]"></div>
          <span class="kah-eyebrow">OR</span>
          <div class="flex-1 h-px bg-white/[0.06]"></div>
        </div>

        <.link
          href={~p"/auth/workos"}
          id="workos-sso-btn"
          class="kah-btn-ghost w-full flex items-center justify-center gap-3"
        >
          <svg
            class="h-4 w-4 shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          Sign in with WorkOS
        </.link>
      <% end %>

      <div class="mt-[18px] pt-[14px] border-t border-white/[0.06] flex items-center justify-between text-[11px]">
        <.link navigate={~p"/onboard"} class="text-[#22c55e] font-semibold hover:underline">
          No account? Create one free
        </.link>
        <span class="font-mono text-gray-600">v2.8 · testnet</span>
      </div>
    </div>
  </div>
</Layouts.app>

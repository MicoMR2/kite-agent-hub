<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href={~p"/images/logo-mark.svg"} />
    <meta
      name="description"
      content={assigns[:meta_description] || "Deploy autonomous AI trading agents on Alpaca and Kalshi. BYO-LLM, non-custodial by design, settled on Kite chain. KCI Edge Scoring rates every position 0–100."}
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Kite Agent Hub" />
    <meta property="og:title" content={assigns[:og_title] || assigns[:page_title] || "Kite Agent Hub — Autonomous AI trading agents"} />
    <meta
      property="og:description"
      content={assigns[:meta_description] || "Deploy AI trading agents that execute on Alpaca and Kalshi, scored with KCI Edge Scoring, settled on Kite chain. BYO-LLM. Non-custodial."}
    />
    <meta property="og:url" content={KiteAgentHubWeb.Endpoint.url() <> (assigns[:request_path] || "/")} />
    <meta property="og:image" content={KiteAgentHubWeb.Endpoint.url() <> "/images/og-image.png"} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kite Agent Hub — autonomous AI agents that trade while you sleep" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={assigns[:og_title] || assigns[:page_title] || "Kite Agent Hub — Autonomous AI trading agents"} />
    <meta
      name="twitter:description"
      content={assigns[:meta_description] || "Deploy AI trading agents on Alpaca and Kalshi, settled on Kite chain. BYO-LLM. Non-custodial."}
    />
    <meta name="twitter:image" content={KiteAgentHubWeb.Endpoint.url() <> "/images/og-image.png"} />
    <%!-- Type pairing: Plus Jakarta Sans 600/700/800 (display — calm-but-premium,
         Stripe/Linear-adjacent), Space Grotesk 400/500/600 (body), JetBrains Mono
         400/500 (chain IDs / tickers). Loaded via Bunny Fonts — privacy-preserving
         Google Fonts mirror. --%>
    <%!-- Non-render-blocking font load. `rel="preload"` fetches without
         blocking, then onload promotes to a stylesheet. <noscript>
         fallback covers no-JS clients. font-display=swap on the URL
         already prevents FOIT on the face files themselves. --%>
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.bunny.net/css?family=plus-jakarta-sans:600,700,800|space-grotesk:400,500,600|jetbrains-mono:400,500&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.bunny.net/css?family=plus-jakarta-sans:600,700,800|space-grotesk:400,500,600|jetbrains-mono:400,500&display=swap"
      />
    </noscript>
    <.live_title>
      {assigns[:page_title] || "Kite Agent Hub"}
    </.live_title>
    <script>
      (() => {
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const systemTheme = () => media.matches ? "dark" : "light";
        const setTheme = (theme) => {
          const mode = theme || "system";
          const resolved = mode === "system" ? systemTheme() : mode;

          if (mode === "system") {
            localStorage.removeItem("phx:theme");
          } else {
            localStorage.setItem("phx:theme", mode);
          }

          document.documentElement.setAttribute("data-theme", resolved);
          document.documentElement.setAttribute("data-theme-mode", mode);
        };
        setTheme(localStorage.getItem("phx:theme") || "system");
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        media.addEventListener("change", () => {
          if (!localStorage.getItem("phx:theme")) setTheme("system");
        });
        window.addEventListener("phx:set-theme", (e) => {
          const button = e.target.closest("[data-phx-theme]");
          if (button) setTheme(button.dataset.phxTheme);
        });
      })();
    </script>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="kah-theme-body antialiased selection:bg-[#22c55e]/30">
    {@inner_content}
  </body>
</html>
